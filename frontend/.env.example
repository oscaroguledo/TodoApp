# API Configuration
REACT_APP_API_URL=http://localhost:3000

# Optional: Enable/disable API logging (defaults to NODE_ENV === 'development')
# REACT_APP_ENABLE_API_LOGGING=true

# Optional: API timeout in milliseconds (defaults to 10000)
# REACT_APP_API_TIMEOUT=10000

# Optional: Enable API request retry (defaults to true)
# REACT_APP_ENABLE_RETRY=true

# Optional: Number of retry attempts (defaults to 3)
# REACT_APP_RETRY_ATTEMPTS=3

# Optional: Authentication token (for development/testing)
# REACT_APP_AUTH_TOKEN=your-jwt-token-here
